<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TLD_Mod_Manager.Converters"
             xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
             x:Class="TLD_Mod_Manager.App">
    
    <Application.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StringToBitmapConverter x:Key="StringToBitmap"/>
    </Application.Resources>
    
    <Application.Styles>
        <themes:MaterialTheme BaseTheme="Dark" PrimaryColor="Blue" SecondaryColor="Amber" />
    </Application.Styles>
</Application>

