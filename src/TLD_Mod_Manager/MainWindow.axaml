<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TLD_Mod_Manager"
        xmlns:i="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="TLD_Mod_Manager.MainWindow"
        x:Name="RootWindow"
        x:DataType="local:MainWindowViewModel"
        Title="TLD Mod Manager"
        Width="1000" Height="700"
        Background="{DynamicResource MaterialDesignBackground}">

    <Design.DataContext>
        <local:MainWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="20,10" Spacing="5">
            <TextBlock Text="The Long Dark Mod Manager" Classes="Headline4" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Mods.Count, StringFormat='{}{0} mods available'}" Classes="Subtitle1" HorizontalAlignment="Center"/>
            <Button Content="Select Game Folder" Command="{Binding SelectGamePathCommand}" Margin="0,5" HorizontalAlignment="Center"/>
            <Button Content="Install MelonLoader" Command="{Binding InstallMelonLoaderCommand}" Margin="5"/>
            <TextBlock Text="{Binding GamePath}" Classes="Caption" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        </StackPanel>
        
        <TextBox Grid.Row="1"
                 Watermark="Search mods..."
                 Margin="20,0,20,10"
                 Classes="Outline"
                 Text="{Binding SearchText, Mode=TwoWay}"/>
        
        <Grid Grid.Row="2" IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="300" Height="8"/>
                <TextBlock Text="Fetching mods..." Classes="Body2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding FilteredMods}"
                 Margin="20,0,20,20"
                 IsVisible="{Binding !IsLoading}"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:Mod">
                    <Border Classes="Card" Margin="0,0,0,10" Padding="16">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" Classes="Headline6"/>
                                    <TextBlock Text="{Binding Version}"
                                               Classes="Caption"
                                               Foreground="{DynamicResource MaterialDesignBodyTextLight}"/>
                                    <Border IsVisible="{Binding TftftDlcRequired}"
                                            Background="{DynamicResource MaterialDesignChipBackground}"
                                            CornerRadius="12" Padding="8,2">
                                        <TextBlock Text="TFTFT" Classes="Overline"/>
                                    </Border>
                                    <Border IsVisible="{Binding IsLibrary}"
                                            Background="{DynamicResource MaterialDesignChipBackground}"
                                            CornerRadius="12" Padding="8,2">
                                        <TextBlock Text="LIBRARY" Classes="Overline"/>
                                    </Border>
                                    <Border IsVisible="{Binding IsPlugin}"
                                            Background="{DynamicResource MaterialDesignChipBackground}"
                                            CornerRadius="12" Padding="8,2">
                                        <TextBlock Text="PLUGIN" Classes="Overline"/>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        CornerRadius="12" Padding="12,4">
                                    <TextBlock Text="{Binding Status}"
                                               Classes="Button"
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                            
                            <Grid ColumnDefinitions="80, *" RowDefinitions="Auto, Auto">
                                <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        CornerRadius="4" Margin="0,0,12,0"
                                        Width="80" Height="80">
                                    <Image Source="/Assets/images/Placeholder.png" 
                                           Stretch="UniformToFill"/>
                                </Border>

                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Description}"
                                           Classes="Body2"
                                           TextWrapping="Wrap"
                                           MaxHeight="60"/>

                                <StackPanel Grid.Column="1" Grid.Row="1" 
                                            Orientation="Horizontal" Spacing="16"
                                            Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <i:MaterialIcon Kind="Person" 
                                                        Foreground="{DynamicResource MaterialDesignBodyTextLight}"/>
                                        <TextBlock Text="{Binding Author}" Classes="Caption"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <i:MaterialIcon Kind="Calendar" 
                                                        Foreground="{DynamicResource MaterialDesignBodyTextLight}"/>
                                        <TextBlock Text="{Binding LastUpdated}" Classes="Caption"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <WrapPanel>
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                                    CornerRadius="12" Padding="8,2"
                                                    Margin="0,0,4,4">
                                                <TextBlock Text="{Binding}" Classes="Overline"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Classes="Text" Content="Details"
                                        Command="{Binding DataContext.ShowDetailsCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding .}"/>
                                <Button Classes="Primary" Content="Install"
                                        Command="{Binding DataContext.InstallCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding .}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>